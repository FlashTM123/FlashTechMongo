{
  "phases": {
    "setup": {
      "aptPkgs": ["libicu-dev", "libzip-dev", "zip", "unzip"]
    },
    "build": {
      "cmds": [
        "composer install --ignore-platform-reqs",
        "npm install",
        "npm run build"
      ]
    }
  },
  "start": {
    "cmd": "php artisan serve --host 0.0.0.0 --port $PORT"
  }
}